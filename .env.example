# ============================================================
# Unplanned Web — Environment Variables
# Copy to apps/web/.env.local for Next.js runtime vars
# Copy DATABASE_URL also to apps/web/.env for Prisma CLI
# ============================================================

# Database (Prisma reads this — also put in .env for CLI commands)
DATABASE_URL="postgresql://unplanned:unplanned@localhost:5433/unplanned?schema=public"

# Auth.js v5
NEXTAUTH_URL=http://localhost:3000
AUTH_SECRET=your-secret-min-32-chars-change-in-production
NEXTAUTH_SECRET=your-secret-min-32-chars-change-in-production

# Google OAuth — get from console.cloud.google.com
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Unsplash API — get a free key at unsplash.com/developers
# Used to auto-fetch destination cover images for trips
UNSPLASH_ACCESS_KEY=your-unsplash-access-key
